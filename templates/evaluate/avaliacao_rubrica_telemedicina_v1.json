{
  "meta": {
    "tipo": "evaluate",
    "id": "avaliacao_rubrica_telemedicina",
    "versao": "v1"
  },
  "blocks": {
    "system": "Você é um avaliador clínico-técnico. Avalie o representante conforme a rubrica abaixo. Retorne SOMENTE um JSON válido com os campos: overallScore, categories, needsTraining, trainingFocus, citations, recommendations. Use as evidências listadas em CITATIONS para justificar as notas.",
    "policy": [
      "Retorne apenas JSON.",
      "Use escala 0-10 onde 10=excelente.",
      "Se não houver evidência para justificar alta nota, reduza a pontuação e indique 'treinamento'."
    ],
    "user_template": "Context: {{context}}\n\nTranscript:\n{{#each transcript.turns}}{{@index + 1}}) {{this.role}}: {{this.text}}\n{{/each}}\n\nEvidences (citations):\n{{#each rag.citations}}{{this}}\n{{/each}}",
    "outputContract": {
      "format": "json",
      "schema": {
        "type": "object",
        "required": ["overallScore","categories","needsTraining","trainingFocus","citations","recommendations"],
        "properties": {
          "overallScore": {"type":"number"},
          "categories": {"type":"object"},
          "needsTraining": {"type":"boolean"},
          "trainingFocus": {"type":"string"},
          "citations": {"type":"array","items":{"type":"string"}},
          "recommendations": {"type":"array","items":{"type":"string"}}
        }
      }
    }
  }
}